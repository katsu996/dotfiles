{
  "base_keymap": "VSCode",
  "icon_theme": "Catppuccin Macchiato",
  "theme": "One Dark Pro",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "tab_size": 2,
  "buffer_font_family": "Menlo",
  "buffer_font_fallbacks": ["Hiragino Sans", "Hiragino Kaku Gothic ProN"],
  "ui_font_fallbacks": ["Hiragino Sans"],
  "project_panel": {
    "dock": "left",
    "git_status": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "terminal": {
    "dock": "bottom",
  },
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "disable_ai": true,
  "show_whitespaces": "all",
  "confirm_quit": true,
  "restore_on_startup": "last_session",
  "inlay_hints": {
    "enabled": true,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "location": "inline",
    },
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
  },
}
